# Server Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/ai_archaeologist?schema=public"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# File Upload Configuration
MAX_FILE_SIZE=104857600
UPLOAD_DIR=./uploads
REPOSITORIES_DIR=./repositories

# IBM Bob AI Configuration
IBM_BOB_API_URL=https://api.ibm.com/bob/v1
IBM_BOB_API_KEY=your-ibm-bob-api-key
IBM_BOB_MODEL=ibm-bob-v1
IBM_BOB_MAX_TOKENS=4096
IBM_BOB_TEMPERATURE=0.7

# Redis Configuration (for Bull queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# GitHub Integration (optional)
GITHUB_TOKEN=your-github-personal-access-token

# Storage Configuration (optional - for S3/cloud storage)
STORAGE_TYPE=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Email Configuration (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@ai-archaeologist.com

# Analytics (optional)
ANALYTICS_ENABLED=false
ANALYTICS_API_KEY=

# Feature Flags
ENABLE_GITHUB_INTEGRATION=true
ENABLE_DOCUMENTATION_GENERATION=true
ENABLE_TECHNICAL_DEBT_ANALYSIS=true
ENABLE_ARCHITECTURE_VISUALIZATION=true